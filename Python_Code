from bs4 import BeautifulSoup
import requests
import time
import csv

print("Enter a skill you are NOT familiar with:")
unfamiliar_skill = input('> ').lower()

print(f"Filtering out jobs with skill: {unfamiliar_skill}")


def find_jobs():
    try:
        url = 'https://timesjobs.com/candidate/job-search.html?searchType=personalizedSearch&from=submit&txtKeywords=python&txtLocation='
        response = requests.get(url)
        response.raise_for_status()

        soup = BeautifulSoup(response.text, 'html.parser')

        jobs = soup.find_all('li', class_='clearfix job-bx wht-shd-bx')

        job_list = []

        for job in jobs:
            published_date = job.find('span', class_='sim-posted').span.text

            # Only recent jobs
            if 'few' in published_date.lower():

                company = job.find('h3', class_='joblist-comp-name').text.strip()
                skills = job.find('span', class_='srp-skills').text.strip()
                link = job.header.h2.a['href']

                if unfamiliar_skill not in skills.lower():
                    job_list.append([company, skills, published_date, link])

        return job_list

    except Exception as e:
        print("Error:", e)
        return []


def save_to_csv(jobs):
    with open('jobs.csv', 'w', newline='', encoding='utf-8') as file:
        writer = csv.writer(file)
        writer.writerow(['Company', 'Skills', 'Posted', 'Link'])
        writer.writerows(jobs)


if __name__ == "__main__":
    while True:
        jobs = find_jobs()

        if jobs:
            print(f"\nFound {len(jobs)} matching jobs:\n")
            for job in jobs:
                print(f"Company: {job[0]}")
                print(f"Skills: {job[1]}")
                print(f"Posted: {job[2]}")
                print(f"Link: {job[3]}")
                print("-" * 40)

            save_to_csv(jobs)
            print("\nData saved to jobs.csv")

        else:
            print("No matching jobs found.")

        time_wait = 10
        print(f"\nWaiting {time_wait} minutes... (Press Ctrl+C to stop)")
        time.sleep(time_wait * 60)
